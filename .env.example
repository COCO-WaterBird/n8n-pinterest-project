# Copy to .env and fill in (never commit .env).
# For Docker Compose, these are passed into the n8n container.

# --- OAuth script: scripts/pinterest-login.mjs (fill before fetching tokens) ---
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# Must exactly match the "Redirect link" configured in your Pinterest app
# (default includes a trailing slash)
# PINTEREST_REDIRECT_URI=http://localhost:8085/
# Token exchange API base:
# Production https://api.pinterest.com, Sandbox https://api-sandbox.pinterest.com
# PINTEREST_API_URI=https://api.pinterest.com

# --- n8n / API calls ---
# Pinterest OAuth access token (Bearer). Get it with npm run pinterest:login.
PINTEREST_ACCESS_TOKEN=

# Optional: override API host (no trailing slash). Production: https://api.pinterest.com
PINTEREST_API_BASE=https://api-sandbox.pinterest.com

# Optional: spreadsheet path used by the OAuth demo.
# If unset, it tries sheet-data/pinterestdoc.xlsx first,
# then sheet-template/pinterestdoc.xlsx.
# PINTEREST_DOC_PATH=/absolute/path/to/pinterestdoc.xlsx
